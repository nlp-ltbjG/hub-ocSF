def log(msg: str):                                       # 定义一个叫 log 的函数，接收一个字符串参数 msg，: str 是类型注解表示参数必须是字符串
    print(msg, file=sys.stderr, flush=True)             # 把消息打印到 stderr（标准错误输出，不是 stdout），flush=True 表示立即输出不缓冲；因为 stdout 是 MCP 协议通道，普通文本只能写 stderr


mcp = FastMCP("weather-server")                         # 创建一个 FastMCP 实例，名字叫 "weather-server"，这是这个服务的身份标识，对端连接时会看到这个名字


@mcp.tool()                                              # 装饰器：把下面这个 Python 函数注册为 MCP 工具
def get_weather(city: str) -> str:                      # 定义 get_weather 函数，参数 city 是城市中文名
    """                                                   # 函数文档字符串开始
    查询指定城市的当前天气及未来3天预报。                     # 功能描述：查询当前天气加未来 3 天预报

    Args:                                                 # 参数说明标签
        city: 城市中文名，如 '宁德'、'北京'。同名地名会自动取行政级别更高的（如福建宁德而非西藏宁德）。  # 对 city 参数的详细说明

    Returns:                                              # 返回值说明标签
        包含温度、湿度、风速、天气状况和3天预报的文字描述。  # 对返回值的描述
    """                                                   # 函数文档字符串结束
    return _get_weather(city)                             # 调用真正的后端函数获取天气信息


@mcp.tool()                                              # 装饰器：把下面这个函数也注册为 MCP 工具
def get_coordinates(city: str) -> str:                   # 定义 get_coordinates 函数，参数 city 是城市中文名，返回值是含坐标的文本
    """                                                   # 函数文档字符串开始
    查询指定城市的经纬度坐标。                                # 功能描述：查经纬度

    Args:                                                 # 参数说明标签
        city: 城市中文名，如 '宁德'、'北京'。同名地名会自动取行政级别更高的（如福建宁德而非西藏宁德）。  # 参数说明

    Returns:                                              # 返回值说明标签
        包含城市全称、经纬度坐标、国家和省份的文字描述。      # 返回值的描述
    """                                                   # 函数文档字符串结束
    return _get_coordinates(city)                         # 调用真正的后端函数获取坐标信息


if __name__ == "__main__":                               # Python 惯用写法：只有当这个文件被直接运行时才执行下面的代码，被 import 时不执行
